model Game {
    id         String @id @default(cuid())
    externalId String @unique

    name          String
    description   String?
    imageUrl      String?
    yearPublished String?

    rank       Int @default(0)
    minPlayers Int @default(0) @map("min_players")
    maxPlayers Int @default(0) @map("max_players")
    minPlaytime Int @default(0) @map("min_playtime")
    maxPlaytime Int @default(0) @map("max_playtime")

    metaScore Float @default(0) @map("meta_score")

    genres       GameGenre[]
    userGames    UserGame[]
    reviews      Review[]
    playSessions PlaySession[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("games")
}
