model User {
    id        String  @id @default(cuid())
    email     String  @unique
    username  String  @unique
    password  String
    name      String?
    avatarUrl String?

    userGames    UserGame[]
    reviews      Review[]
    playSessions PlaySession[]

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@map("users")
}
